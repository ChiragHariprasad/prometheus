# PROMETHEUS Environment Configuration

# Application
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=prometheus
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-384-bit-minimum
JWT_ALGORITHM=HS256  # Changed from RS256 for dev; TODO: Production — use RS256 with key pair
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_REGISTRY_URI=http://mlflow:5000

# Embedding Model
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ClickHouse Analytics  # TODO: Production — not wired in current build
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_DATABASE=prometheus_analytics

# AWS S3  # TODO: Production — not configured in current build
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Notifications  # TODO: Production — not wired (SendGrid, Twilio, FCM)
NOTIFICATION_SENDGRID_API_KEY=
NOTIFICATION_TWILIO_ACCOUNT_SID=
NOTIFICATION_TWILIO_AUTH_TOKEN=
NOTIFICATION_FCM_CREDENTIALS=

# Monitoring  # TODO: Production — Sentry/OpenTelemetry not wired
SENTRY_DSN=
OPENTELEMETRY_ENABLED=true
OPENTELEMETRY_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Grafana
GRAFANA_PASSWORD=admin
